generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id
  email        String   @unique
  passwordHash String?
  name         String?
  provider     String?  // google, apple, email
  providerId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  properties Property[]
  tenants    Tenant[]
}

model Property {
  id         String         @id @default(cuid())
  userId     String
  name       String
  floor      Int
  roomNumber String
  area        Float          // 坪數
  monthlyRent Int
  status      PropertyStatus @default(VACANT)
  facilities String[]
  photos     String[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user                User                 @relation(fields: [userId], references: [id])
  leases              Lease[]
  meterReadings       MeterReading[]
  maintenanceRequests MaintenanceRequest[]

  @@index([userId])
}

enum PropertyStatus {
  VACANT
  OCCUPIED
  MAINTENANCE
  ARCHIVED
}

model Tenant {
  id          String    @id @default(cuid())
  userId      String
  name        String
  phone       String
  email       String?
  idNumber    String?
  lineId      String?
  moveInDate  DateTime?
  moveOutDate DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user                User                 @relation(fields: [userId], references: [id])
  leases              Lease[]
  maintenanceRequests MaintenanceRequest[]
  documents           TenantDocument[]
  emergencyContacts   EmergencyContact[]

  @@index([userId])
}

model EmergencyContact {
  id           String  @id @default(cuid())
  tenantId     String
  name         String
  phone        String
  isCoResident Boolean @default(false)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TenantDocument {
  id        String   @id @default(cuid())
  tenantId  String
  type      String   // ID_CARD, CONTRACT, OTHER
  name      String
  url       String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Lease {
  id          String      @id @default(cuid())
  propertyId  String
  tenantId    String
  startDate   DateTime
  endDate     DateTime
  monthlyRent Int
  deposit     Int
  terms       String?
  status      LeaseStatus @default(ACTIVE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  property Property  @relation(fields: [propertyId], references: [id])
  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  payments Payment[]

  @@index([propertyId])
  @@index([tenantId])
}

enum LeaseStatus {
  ACTIVE
  EXPIRED
  TERMINATED
}

model Payment {
  id       String        @id @default(cuid())
  leaseId  String
  amount   Int
  dueDate  DateTime
  paidDate DateTime?
  status   PaymentStatus @default(PENDING)
  method   PaymentMethod?
  receipt  String?
  createdAt DateTime     @default(now())

  lease Lease @relation(fields: [leaseId], references: [id])

  @@index([leaseId])
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
}

enum PaymentMethod {
  CASH
  TRANSFER
}

model MeterReading {
  id          String    @id @default(cuid())
  propertyId  String
  type        MeterType
  reading     Float
  readingDate DateTime
  createdAt   DateTime  @default(now())

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
}

enum MeterType {
  WATER
  ELECTRICITY
}

model MaintenanceRequest {
  id          String              @id @default(cuid())
  propertyId  String
  tenantId    String?
  category    String
  description String
  priority    MaintenancePriority @default(MEDIUM)
  status      MaintenanceStatus   @default(PENDING)
  cost        Int?
  photos      String[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  property Property @relation(fields: [propertyId], references: [id])
  tenant   Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([propertyId])
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MaintenanceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}
